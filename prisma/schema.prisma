generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js Required Models ──────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   @db.Text
  firstName        String?
  lastName         String?
  specializationId String?

  specialization Specialization? @relation(fields: [specializationId], references: [id])
  accounts       Account[]
  sessions   Session[]
  roles      UserRole[]
  shifts     Shift[]
  preferences UserPreference[]
  blockDays  BlockDay[]
  evolutions      Evolution[]
  auditLogs       AuditLog[]
  prescriptions   Prescription[]
  studyOrders     StudyOrder[]
  mealPlans       MealPlan[]
  notifications   Notification[]
  moduleAccess    UserModuleAccess[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
  @@index([specializationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Profession Configs ──────────────────────────────────────────────────────

model ProfessionConfig {
  id                  String @id @default(cuid())
  code                String @unique    // "medic", "psychologist", "dentist"
  name                String            // "Médico", "Psicólogo", "Dentista"
  professionalLabel   String            // "Dr/a.", "Lic.", "Od."
  patientLabel        String @default("Paciente")
  prescriptionLabel   String            // "Receta", "Indicación", "Plan de tratamiento"
  evolutionLabel      String            // "Evolución", "Nota de sesión", "Registro odontológico"
  clinicalRecordLabel String            // "Historia Clínica", "Ficha Psicológica", "Ficha Dental"
  enabledModules      String @db.Text   // JSON: ["prescriptions","study_orders"]
  clinicalFields      String @db.Text   // JSON: campos del template de HC

  specializations Specialization[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Specializations ─────────────────────────────────────────────────────────

model Specialization {
  id                 String @id @default(cuid())
  name               String @unique
  professionConfigId String?

  professionConfig ProfessionConfig? @relation(fields: [professionConfigId], references: [id])
  users            User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([professionConfigId])
}

// ─── Consultation Types ─────────────────────────────────────────────────────

model ConsultationType {
  id              String  @id @default(cuid())
  name            String  @unique // "Primera vez", "Control", "Urgencia"
  durationMinutes Int              // 40, 20, 15
  color           String?          // Color hex opcional
  isDefault       Boolean @default(false)

  shifts Shift[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Roles ────────────────────────────────────────────────────────────────────

model Role {
  id   String @id @default(cuid())
  name String @unique // "medic", "secretary", "admin"

  users UserRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// ─── Patients ─────────────────────────────────────────────────────────────────

model Patient {
  id        String  @id @default(cuid())
  firstName String
  lastName  String
  birthDate DateTime?
  sex       String?           // "M", "F", "X"
  dni       String?  @unique
  email     String?
  telephone String?
  address   String?
  country   String?
  province  String?
  osId      String?
  osNumber  String?

  os             HealthInsurance? @relation(fields: [osId], references: [id])
  shifts         Shift[]
  clinicalRecord ClinicalRecord?
  prescriptions  Prescription[]
  studyOrders    StudyOrder[]
  mealPlans      MealPlan[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([dni])
  @@index([osId])
}

// ─── Health Insurance (Obra Social) ───────────────────────────────────────────

model HealthInsurance {
  id   String  @id @default(cuid())
  name String
  code String?

  patients Patient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Shifts (Turnos) ─────────────────────────────────────────────────────────

enum ShiftStatus {
  PENDING
  CONFIRMED
  ABSENT
  FINISHED
  CANCELLED
}

model Shift {
  id              String      @id @default(cuid())
  userId          String
  patientId       String
  start           DateTime
  end             DateTime
  observations    String?     @db.Text
  status          ShiftStatus @default(PENDING)
  isOverbook         Boolean     @default(false) // Sobreturno
  consultationTypeId String?
  recurrenceGroupId  String?     // Shared ID for recurring shift series
  rescheduledFrom    DateTime?   // Original date before auto-reschedule
  rescheduledAt      DateTime?   // When the auto-reschedule happened

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  consultationType ConsultationType? @relation(fields: [consultationTypeId], references: [id], onDelete: SetNull)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  evolution     Evolution?
  prescriptions Prescription[]
  studyOrders   StudyOrder[]
  mealPlans     MealPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([patientId])
  @@index([start])
}

// ─── User Preferences ────────────────────────────────────────────────────────

model UserPreference {
  id        String @id @default(cuid())
  userId    String
  day       Int    // 0=Sunday, 1=Monday, ..., 6=Saturday
  fromHourAM String?
  toHourAM   String?
  fromHourPM String?
  toHourPM   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, day])
  @@index([userId])
}

// ─── Blocked Days ─────────────────────────────────────────────────────────────

model BlockDay {
  id     String   @id @default(cuid())
  userId String
  date   DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
}

// ─── Password Reset Tokens ───────────────────────────────────────────────────

model ResetToken {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique
  expires    DateTime
  used       Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

// ─── Clinical History (Historia Clínica) ─────────────────────────────────────

model ClinicalRecord {
  id            String   @id @default(cuid())
  patientId     String   @unique
  bloodType     String?  // A+, A-, B+, B-, AB+, AB-, O+, O-
  allergies     String?  @db.Text
  personalHistory String? @db.Text  // antecedentes personales
  familyHistory   String? @db.Text  // antecedentes familiares
  currentMedication String? @db.Text // medicación habitual
  notes         String?  @db.Text
  customFields  String?  @db.Text   // JSON: campos custom por profesión

  patient    Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  evolutions Evolution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
}

model Evolution {
  id              String  @id @default(cuid())
  clinicalRecordId String
  shiftId         String? @unique
  userId          String  // medic who wrote it

  reason          String?  @db.Text  // motivo de consulta
  physicalExam    String?  @db.Text  // examen físico
  diagnosis       String?  @db.Text  // diagnóstico
  diagnosisCode   String?            // CIE-10 code
  treatment       String?  @db.Text  // plan/tratamiento
  indications     String?  @db.Text  // indicaciones
  notes           String?  @db.Text

  clinicalRecord ClinicalRecord @relation(fields: [clinicalRecordId], references: [id], onDelete: Cascade)
  shift          Shift?         @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  user           User           @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicalRecordId])
  @@index([userId])
  @@index([shiftId])
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String  @id @default(cuid())
  userId     String
  action     String  // CREATE, UPDATE, DELETE, VIEW_SENSITIVE
  resource   String  // patient, shift, evolution, clinical_record, etc.
  resourceId String
  details    String? @db.Text // JSON con cambios o contexto
  ipAddress  String?
  userAgent  String?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@index([action])
}

// ─── Module System ───────────────────────────────────────────────────────────

model ModuleConfig {
  id      String  @id @default(cuid())
  module  String  @unique // "prescriptions", "lab_orders", etc.
  name    String  // Display name
  enabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserModuleAccess {
  id      String  @id @default(cuid())
  userId  String
  module  String
  enabled Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
  @@index([userId])
}

// ─── Prescriptions (Recetas) ─────────────────────────────────────────────────

model Prescription {
  id          String  @id @default(cuid())
  patientId   String
  userId      String  // médico que receta
  shiftId     String? // turno asociado
  items       String  @db.Text // JSON array of PrescriptionItem
  diagnosis   String?
  notes       String? @db.Text

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
  shift   Shift?  @relation(fields: [shiftId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([userId])
  @@index([shiftId])
}

// ─── Meal Plans (Planes Alimentarios) ────────────────────────────────────────

model MealPlan {
  id              String  @id @default(cuid())
  userId          String                     // Nutricionista
  patientId       String
  shiftId         String?
  title           String                     // "Plan hipocalorico", "Plan normocalorico"
  targetCalories  Int?                       // kcal/dia
  proteinPct      Int?                       // % proteinas
  carbsPct        Int?                       // % carbohidratos
  fatPct          Int?                       // % grasas
  hydration       String?                    // "2 litros de agua"
  meals           String  @db.Text           // JSON: MealSection[]
  avoidFoods      String? @db.Text           // Alimentos a evitar
  supplements     String? @db.Text           // Suplementos
  notes           String? @db.Text           // Observaciones generales

  user    User    @relation(fields: [userId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  shift   Shift?  @relation(fields: [shiftId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([userId])
}

// ─── Medications (Vademécum) ─────────────────────────────────────────────────

model Medication {
  id           String  @id @default(cuid())
  name         String  @unique
  genericName  String?
  presentation String? // ej: "Comprimidos 500mg"
  category     String? // ej: "Analgésico", "Antibiótico"

  createdAt DateTime @default(now())
}

// ─── Study Orders (Ordenes de Estudios) ─────────────────────────────────────

enum StudyOrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model StudyOrder {
  id          String           @id @default(cuid())
  userId      String                          // Medico que ordena
  patientId   String
  shiftId     String?                         // Turno asociado
  items       String           @db.Text       // JSON array of StudyOrderItem
  status      StudyOrderStatus @default(PENDING)
  resultNotes String?          @db.Text       // Notas de resultados

  user    User    @relation(fields: [userId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  shift   Shift?  @relation(fields: [shiftId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([userId])
  @@index([shiftId])
  @@index([status])
}

// ─── Notifications ──────────────────────────────────────────────────────────

model Notification {
  id         String  @id @default(cuid())
  userId     String                 // Destinatario
  type       String                 // "pending_studies", "inactive_patient", "rescheduled"
  title      String
  message    String  @db.Text
  resourceId String?                // ID del recurso relacionado
  read       Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}
