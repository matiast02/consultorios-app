# ─── Database (MySQL) ────────────────────────────────────────────────────────
# Development: uses docker-compose MySQL on port 3307
DATABASE_URL="mysql://app_user:app_password_2024@localhost:3307/consultorio"

# Production: point to your MySQL instance
# DATABASE_URL="mysql://user:password@host:3306/consultorio"

# ─── Auth.js ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# ─── OAuth Providers (optional) ──────────────────────────────────────────────
# GitHub — https://github.com/settings/developers
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google — https://console.cloud.google.com/
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── App URL ─────────────────────────────────────────────────────────────────
# Development
NEXTAUTH_URL="http://localhost:3000"

# Production: set to your domain
# NEXTAUTH_URL="https://tu-dominio.com"
